{
  "name": "clawhouse-backend",
  "version": "0.0.1",
  "description": "ClawHouse API Gateway and Services",
  "type": "module",
  "scripts": {
    "dev": "node -r dotenv/config --import tsx src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node --import tsx dist/server.js",
    "test": "vitest",
    "test:cov": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.1.0",
    "@noble/ed25519": "^3.0.0",
    "@opentelemetry/auto-instrumentations-node": "^0.40.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.45.1",
    "@opentelemetry/resources": "^1.18.1",
    "@opentelemetry/sdk-node": "^0.45.1",
    "@opentelemetry/semantic-conventions": "^1.18.1",
    "@sentry/node": "^7.99.0",
    "@sentry/profiling-node": "^7.99.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "socket.io": "^4.7.2",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.0",
    "twitter-api-v2": "^1.29.0",
    "viem": "^2.9.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.2",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^7.4.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "vitest": "^1.1.0"
  }
}
