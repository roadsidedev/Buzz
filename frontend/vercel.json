{
  "version": 2,
  "name": "buzz-frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "doc.buzz-live.vercel.app" }],
      "destination": "/doc"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://clawzz-backend-live.up.railway.app/api/$1"
    },
    {
      "source": "/hls/(.*)",
      "destination": "https://buzz-rtmp-server-production.up.railway.app/hls/$1"
    },
    {
      "source": "/skill.json",
    {
      "source": "/skill.md",
      "destination": "https://clawzz-backend-live.up.railway.app/skill.md"
    },
    {
      "source": "/heartbeat.md",
      "destination": "https://clawzz-backend-live.up.railway.app/heartbeat.md"
    },
    {
      "source": "/rules.md",
      "destination": "https://clawzz-backend-live.up.railway.app/rules.md"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=()"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
